# Telegram bot token from @BotFather — used to validate Mini App initData.
BOT_TOKEN=

# HTTP/WS port.
PORT=8080

# Secret for signing session JWTs (issued after initData validation).
SESSION_SECRET=change-me

# Dev only: set to "true" to enable POST /auth/dev (login without Telegram).
# NEVER enable in production.
ALLOW_DEV_AUTH=false

# Bot identity for building Direct Mini App invite links
# (https://t.me/<BOT_USERNAME>/<APP_SHORT_NAME>?startapp=<roomCode>).
BOT_USERNAME=
APP_SHORT_NAME=

# Run the Telegram bot (long-polling) that answers /start and /help with a
# welcome message + launch button, and fills in the bot's commands/description.
# Set to "true" to enable. Don't run two pollers (or a webhook) for the same bot.
BOT_POLLING=false
# Public HTTPS URL of the Mini App (e.g. your tunnel URL). When set, /start shows
# a web_app launch button that opens the app inline. Otherwise it falls back to a
# named-app t.me link, or the menu button.
MINI_APP_URL=

# SQLite file for room persistence (rooms survive server restarts).
DB_PATH=allinn.db

# Evict EMPTY rooms (nobody seated) with no connections after this idle (min).
ROOM_TTL_MINUTES=30
# Rooms where someone has taken a seat survive much longer (players gather slowly),
# even if the host's app is backgrounded.
ROOM_ABANDON_MINUTES=720

# Postgres / Redis (for scaling later; not used yet).
DATABASE_URL=
REDIS_URL=
